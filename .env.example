# ─── LLM ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ─── Web search ────────────────────────────────────────────────────────────────
TAVILY_API_KEY=

# ─── Vector DB ─────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333

# ─── MCP tool server ports (default: 9001-9004) ────────────────────────────────
WEB_SEARCH_PORT=9001
VECTOR_DB_PORT=9002
FILE_READER_PORT=9003
CITATION_CHECKER_PORT=9004

# MCP tool URLs (consumed by agent mcp_client.py files)
WEB_SEARCH_MCP_URL=http://localhost:9001/mcp
VECTOR_DB_MCP_URL=http://localhost:9002/mcp
FILE_READER_MCP_URL=http://localhost:9003/mcp
CITATION_CHECKER_MCP_URL=http://localhost:9004/mcp

# ─── A2A agent server ports (default: 8001-8003) ───────────────────────────────
WEB_RESEARCH_PORT=8001
RAG_AGENT_PORT=8002
SUMMARISER_AGENT_PORT=8003

# A2A agent URLs (consumed by orchestrator)
WEB_RESEARCH_AGENT_URL=http://localhost:8001
RAG_AGENT_URL=http://localhost:8002
SUMMARISER_AGENT_URL=http://localhost:8003

# ─── Orchestrator ──────────────────────────────────────────────────────────────
ORCHESTRATOR_PORT=8000
ROUTER_MODEL=gpt-4o-mini
A2A_TIMEOUT=30.0

# ─── LangSmith tracing ─────────────────────────────────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=research-platform
LANGCHAIN_TRACING_V2=true
# Optional: use EU endpoint
# LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
